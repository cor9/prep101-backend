{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "simple-backend-rag.js": {
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "{services,config,models,middleware,routes}/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/simple-backend-rag.js"
    }
  ]
}
